From 4bec4892f8f17d4f3f003144724b01fdc7d7378c Mon Sep 17 00:00:00 2001
From: Nathan Chancellor <nathan@kernel.org>
Date: Tue, 21 Mar 2023 11:13:46 -0700
Subject: [PATCH 7/7] HACK: LONGTERM: powerpc: Do not use '-mcpu=440' with
 clang

Link: https://github.com/ClangBuiltLinux/linux/issues/1814
Signed-off-by: Nathan Chancellor <nathan@kernel.org>
---
 arch/powerpc/platforms/Kconfig.cputype | 1 +
 1 file changed, 1 insertion(+)

diff --git a/arch/powerpc/platforms/Kconfig.cputype b/arch/powerpc/platforms/Kconfig.cputype
index 4c321a8ea896..8098c3a4c1c9 100644
--- a/arch/powerpc/platforms/Kconfig.cputype
+++ b/arch/powerpc/platforms/Kconfig.cputype
@@ -188,6 +188,7 @@ config E6500_CPU
 config 440_CPU
 	bool "440 (44x family)"
 	depends on 44x
+	depends on !CC_IS_CLANG
 
 config 464_CPU
 	bool "464 (44x family)"
-- 
2.53.0

